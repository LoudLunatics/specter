# Maintainer: LoudLunatics <nauvalazfa@proton.me>
pkgname=specter
pkgver=1.2.0
pkgrel=1
pkgdesc="Ghost Network Recon Engine (Standalone Nmap Scanner)"
arch=('any')
url="https://github.com/LoudLunatics/specter"
license=('MIT')

depends=('python' 'python-dotenv' 'python-rich' 'nmap')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')

# --- JALUR BYPASS ANTI 404 ---
# Mengambil langsung dari branch 'main', masa bodoh dengan Tag versi!
source=("$pkgname-main.tar.gz::https://github.com/LoudLunatics/$pkgname/archive/refs/heads/main.tar.gz")

sha256sums=('SKIP')

build() {
  # Masuk ke folder unduhan branch main
  cd "$pkgname-main"
  python -m build --wheel --no-isolation
}

package() {
  # Instalasi ke sistem
  cd "$pkgname-main"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
